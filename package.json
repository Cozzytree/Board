{
  "name": "@dhrubojyotiboro/board",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/lib.d.ts",
  "style": "./dist/board.css",
  "exports": {
    ".": {
      "types": "./dist/types/lib.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/board.css",
    "./board.css": "./dist/board.css"
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "./packages/*"
  ],
  "scripts": {
    "back": "bun run --env-file=./packages/package_websocket/.env ./packages/package_websocket/index.ts",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:app": "tsc && vite build",
    "build:lib": "rm -rf dist && vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "prepublishOnly": "pnpm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.3",
    "@excalidraw/excalidraw": "^0.18.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.127.9",
    "better-auth": "^1.6.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.525.0",
    "perfect-freehand": "^1.2.2",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tanstack/router-plugin": "^1.127.9",
    "@types/node": "^24.0.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.3.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4"
  }
}
