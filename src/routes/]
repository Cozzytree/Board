import { createFileRoute, useNavigate, Outlet } from "@tanstack/react-router";
import React from "react";
import { Menu } from "lucide-react";
import { useSession } from "@/lib/auth-client";
import SidebarPage from "@/components/sidebar_page";
import { ResizableHandle, ResizablePanel, ResizablePanelGroup } from "@/components/ui/resizable";
import { Sheet, SheetContent, SheetTrigger } from "@/components/ui/sheet";
import { useIsMobile } from "@/hooks/use-mobile";
import { Button } from "@/components/ui/button";
import { SidebarProvider } from "@/components/ui/sidebar";

export const Route = createFileRoute("/pages")({
   component: PagesLayout,
});

function PagesLayout() {
   const navigate = useNavigate();
   const { data: session, isPending } = useSession();
   const isMobile = useIsMobile();
   const [isCollapsed, setIsCollapsed] = React.useState(false);
   const panelRef = React.useRef(null);

   React.useEffect(() => {
      if (!isPending && !session) {
         navigate({ to: "/" });
      }
   }, [isPending, session, navigate]);

   if (isPending || !session) {
      return (
         <div className="h-dvh w-full bg-background flex items-center justify-center">
            <div className="h-8 w-8 border-2 border-muted border-t-transparent rounded-full animate-spin" />
         </div>
      );
   }

   if (isMobile) {
      return (
         <SidebarProvider>
            <div className="flex flex-col h-dvh w-full overflow-hidden bg-background">
               <header className="flex h-14 items-center px-4 border-b shrink-0 bg-sidebar/50 backdrop-blur-md">
                  <Sheet>
                     <SheetTrigger asChild>
                        <Button variant="ghost" size="icon">
                           <Menu className="h-5 w-5" />
                        </Button>
                     </SheetTrigger>
                     <SheetContent side="left" className="p-0 w-72 bg-sidebar border-r">
                        <SidebarPage />
                     </SheetContent>
                  </Sheet>
                  <div className="ml-4 font-medium">Board</div>
               </header>
               <main className="flex-1 overflow-hidden relative">
                  <Outlet />
               </main>
            </div>
         </SidebarProvider>
      );
   }

   return (
      <SidebarProvider>
         <div className="relative h-dvh w-full bg-background overflow-hidden flex">
            <ResizablePanelGroup orientation="horizontal" className="h-full w-full">
               {!isCollapsed &&
                  <ResizablePanel
                     elementRef={panelRef}
                     collapsible={true}
                     collapsedSize={0}
                     onClick={() => {
                        setIsCollapsed(true);
                     }}
                     minSize={"10em"}
                     maxSize={"30em"}
                     className={`flex flex-col border-r bg-sidebar h-full transition-all duration-300 ease-in-out`}
                  >
                     <SidebarPage />
                  </ResizablePanel>
               }

               <ResizableHandle
                  withHandle
                  className="cursor-col-resize hover:bg-muted width-20 hover:bg-primary/20 active:bg-primary/20 transition-colors"
                  onMouseOver={() => {
                     if (!isCollapsed) {}
                  }}
                  onClick={() => {
                     setIsCollapsed((v) => !v);
                  }}
               />

               <ResizablePanel defaultSize={80} className="relative overflow-hidden h-full">
                  <Outlet />
               </ResizablePanel>
            </ResizablePanelGroup>
         </div>
      </SidebarProvider>
   );
}

export default PagesLayout;
